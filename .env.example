# ===== Main LLM Configuration =====
# No API key needed! MiroFish uses the Claude Agent SDK,
# which authenticates via your Claude subscription (Claude Pro/Max/Teams).
# Just make sure you are logged into Claude Code: run `claude` and log in.

# Choose your Claude model (optional, defaults to claude-sonnet-4-6)
# Options: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6

# ===== ZEP Memory Graph Configuration =====
# Monthly free quota is sufficient for simple usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerated LLM Configuration (for OASIS simulation) =====
# These are used by the OASIS/camel-ai simulation framework.
# You can use any OpenAI-compatible API (OpenRouter, Ollama, etc.)
# Note: if you don't use accelerated configuration, don't include the following config items in the env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
